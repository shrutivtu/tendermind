# ──────────────────────────────────────────────────────────────────────────────
# TenderMind — Root environment variables
#
# Used by: apps/api and workers/ (loaded via --env-file=../../.env)
# NOT read by Next.js — frontend vars go in apps/web/.env.local
#
# Copy this file to .env and fill in real values.
# .env is gitignored. Never commit secrets.
#
# IN PRODUCTION:
#   - Render (API): set these in Render dashboard → Environment
#   - Workers: set these in whatever runs the ingestion cron
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL + pgvector) ─────────────────────────────────
# Local dev: direct connection URL (IPv6 works on your machine)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Production on Render (IPv6 not supported on free tier):
# Use the Session Pooler URL from Supabase → Settings → Database → Connection Pooling
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:5432/postgres

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── TED (EU procurement data) ─────────────────────────────────────────────────
TED_API_KEY=your_key_here

# ── Translation (optional) ────────────────────────────────────────────────────
DEEPL_API_KEY=your_key_here

# ── API server ────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# CORS origin — which frontend the API accepts requests from.
# Local dev: leave this line commented out (code defaults to http://localhost:3000)
# Production (Render): uncomment and set to your Vercel domain
# WEB_URL=https://your-app.vercel.app
